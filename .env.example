# LLM Providers (set whichever you use — at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# Ollama: no key — auto-detected at http://127.0.0.1:11434/v1

# Default model (provider/model format)
DEFAULT_MODEL=anthropic/claude-sonnet-4-6
ROUTER_MODEL=anthropic/claude-haiku-4-5-20251001
FALLBACK_MODELS=openai/gpt-4o,google/gemini-2.0-flash

# Runtime bootstrapping
BOOTSTRAP_SOURCE=filesystem
HEARTBEAT_COMPANY_IDS=
DB_MIGRATIONS_PATH=packages/db/migrations

# Startup integrations
STRIPE_API_KEY=
LINEAR_API_KEY=
